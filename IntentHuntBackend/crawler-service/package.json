{
  "name": "crawler-service",
  "version": "1.0.0",
  "description": "IntentHunt crawler microservice — fetches Reddit and HN posts for keywords",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "tsx src/api/server.ts",
    "worker": "tsx src/worker/worker.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "apify-client": "^2.22.3",
    "bullmq": "^5.8.0",
    "dotenv": "^17.3.1",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.2",
    "openai": "^6.32.0",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "undici": "^6.18.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^1.6.0",
    "prisma": "^5.22.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
