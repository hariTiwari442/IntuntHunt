generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────

enum JobStatus {
  pending
  running
  completed
  failed
  cancelled
}

enum TaskStatus {
  pending
  running
  completed
  failed
  dead
}

enum SourceType {
  reddit
  hackernews
  linkedin
}

// ── Models ───────────────────────────────────────────────

model CrawlJob {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  keywords     String[]
  sources      SourceType[]
  status       JobStatus  @default(pending)
  startedAt    DateTime?  @map("started_at")
  completedAt  DateTime?  @map("completed_at")
  errorMessage String?    @map("error_message")
  metadata     Json?
  createdAt    DateTime   @default(now()) @map("created_at")

  tasks CrawlTask[]
  posts Post[]

  @@index([userId])
  @@index([status])
  @@map("crawl_jobs")
}

model CrawlTask {
  id            String     @id @default(uuid()) @db.Uuid
  jobId         String     @map("job_id") @db.Uuid
  source        SourceType
  keyword       String
  status        TaskStatus @default(pending)
  attempts      Int        @default(0)
  maxAttempts   Int        @default(3) @map("max_attempts")
  bullmqJobId   String?    @map("bullmq_job_id")
  lastAttemptAt DateTime?  @map("last_attempt_at")
  nextAttemptAt DateTime?  @map("next_attempt_at")
  completedAt   DateTime?  @map("completed_at")
  resultCount   Int        @default(0) @map("result_count")
  errorMessage  String?    @map("error_message")
  createdAt     DateTime   @default(now()) @map("created_at")

  job   CrawlJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  posts Post[]

  @@unique([jobId, source, keyword])
  @@index([jobId, status])
  @@map("crawl_tasks")
}

model Post {
  id             String     @id @default(uuid()) @db.Uuid
  jobId          String     @map("job_id") @db.Uuid
  taskId         String     @map("task_id") @db.Uuid
  source         SourceType
  externalId     String     @map("external_id")
  keyword        String
  title          String
  content        String?
  author         String?
  url            String?
  score          Int?
  commentCount   Int?       @map("comment_count")
  subreddit      String?
  postedAt       DateTime?  @map("posted_at")
  fetchedAt      DateTime   @default(now()) @map("fetched_at")
  intentScore    Decimal?   @map("intent_score") @db.Decimal(5, 2)
  suggestedReply String?    @map("suggested_reply")
  strategy       String?
  rawData        Json?      @map("raw_data")

  job  CrawlJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  task CrawlTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([jobId, source, externalId])
  @@index([jobId, intentScore(sort: Desc)])
  @@map("posts")
}
