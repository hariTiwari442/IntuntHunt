generator client {
  provider      = "prisma-client-js"
  // Generate clients for local dev (native) AND Cloud Run's Debian-based runtime
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Profiles ─────────────────────────────────────────────
// Extends Supabase auth.users with app-specific data.
// The id comes from Supabase Auth (auth.users.id).
model Profile {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  name          String?
  avatarUrl     String?  @map("avatar_url")

  // ── Subscription / Plan ─────────────────────────────────────────
  plan                  String    @default("starter")        // "starter" | "pro" | "agency"
  planStatus            String    @default("active") @map("plan_status")        // "active" | "trialing" | "past_due" | "canceled" | "paused" | "incomplete"
  // Dodo Payments IDs. DB columns kept under their original "paddle_*" names
  // so we don't need a migration — they're opaque billing IDs to our app.
  dodoCustomerId        String?   @unique @map("paddle_customer_id")
  dodoSubscriptionId    String?   @unique @map("paddle_subscription_id")
  trialEndsAt           DateTime? @map("trial_ends_at")
  currentPeriodEnd      DateTime? @map("current_period_end")
  cancelAtPeriodEnd     Boolean   @default(false) @map("cancel_at_period_end")
  billingInterval       String?   @map("billing_interval")   // "month" | "year"
  // ────────────────────────────────────────────────────────────────

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  products      Product[]

  @@map("profiles")
  @@index([dodoCustomerId])
  @@index([dodoSubscriptionId])
}

// ── Webhook event idempotency tracking ───────────────────────────
// One row per Dodo (Svix) event we've processed. Prevents duplicate
// handling if Dodo retries on any non-200 response.
// DB table kept as "paddle_events" so no migration is needed.
model DodoEvent {
  id          String   @id            // Svix webhook-id header value
  eventType   String   @map("event_type")
  processedAt DateTime @default(now()) @map("processed_at")
  payload     Json     // full event payload, for debugging

  @@map("paddle_events")
  @@index([eventType])
  @@index([processedAt])
}

// ── Products ──────────────────────────────────────────────
// Stores the keyword intelligence + Google-search queries for each product.
// `queries` shape: { redditGlobal: string[], redditSubreddit: Record<string, string[]>,
//                    linkedin: string[], twitter: string[], producthunt: string[],
//                    indiehackers: string[] }
// Subreddits list is derived from Object.keys(redditSubreddit), kept here
// for convenience + display.
model Product {
  id           String   @id @default(uuid())
  userId       String   @map("user_id") @db.Uuid
  name         String   @default("")
  description  String
  productUrl   String?  @map("product_url")
  intelligence Json     // ProductIntelligence
  queries      Json     // QueryBundle (per-platform site: queries)
  subreddits   String[] // derived from queries.redditSubreddit keys
  lastSearchedAt DateTime? @map("last_searched_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         Profile  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("products")
}
